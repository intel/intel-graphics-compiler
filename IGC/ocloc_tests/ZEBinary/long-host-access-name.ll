; This test verifies that the global_host_access_table in .ze_info correctly
; contains device_name and host_name strings exceeding 1024 characters,
; exercising the refactored CreateGlobalHostAccessTable that uses std::string
; instead of the legacy char[1024] + strcpy_s path.
; Device name length: 1095, Host name length: 1093.

; UNSUPPORTED: sys32
; REQUIRES: llvm-spirv, oneapi-readelf
; RUN: llvm-as %s -o %t.bc
; RUN: llvm-spirv %t.bc --spirv-ext=+SPV_INTEL_global_variable_host_access -o %t.spv
; RUN: ocloc compile -spirv_input -file %t.spv -o %t.progbin -device bmg
; RUN: oneapi-readelf -p .ze_info %t.progbin | FileCheck %s

; CHECK: device_name:{{.*}}device_var_{{D+}}_end
; CHECK: host_name:{{.*}}host_var_{{H+}}_end

target triple = "spir64-unknown-unknown"

@device_var__end = addrspace(1) global [4 x i32] [i32 0, i32 0, i32 64, i32 64], !spirv.Decorations !3

define spir_kernel void @test_kernel(i32 addrspace(1)* %out) {
entry:
  %ptr = getelementptr [4 x i32], [4 x i32] addrspace(1)* @device_var__end, i64 0, i64 0
  %val = load i32, i32 addrspace(1)* %ptr
  store i32 %val, i32 addrspace(1)* %out
  ret void
}

!spirv.MemoryModel = !{!0}
!spirv.Source = !{!1}
!opencl.spir.version = !{!2}
!opencl.ocl.version = !{!2}

!0 = !{i32 2, i32 2}
!1 = !{i32 3, i32 102000}
!2 = !{i32 1, i32 2}
!3 = !{!4}
!4 = !{i32 6188, i32 3, !"host_var__end"}
