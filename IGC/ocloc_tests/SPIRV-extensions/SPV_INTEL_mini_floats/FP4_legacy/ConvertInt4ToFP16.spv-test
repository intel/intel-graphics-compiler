; CHECK: shfl_idx4 ({{.*}}, 32) [[DST0:[A-z0-9]*]].0 [[LUT_SRC:[A-z0-9]*]](0,0)<0;16,1> [[INPUT:[A-z0-9]*]](0,0)<4;1,0>
