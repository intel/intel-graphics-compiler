; REQUIRES: regkeys, spirv-as, dg2-supported, pvc-supported
; RUN: spirv-as --target-env spv1.0 -o %t.spv %s
; RUN: %if !release %{ ocloc compile -spirv_input -file %t.spv -device dg2 -options " -igc_opts 'ShaderDumpTranslationOnly=1'" 2>&1 | FileCheck %s --check-prefix=CHECK-TRANSLATE %}
;
; DG2: no native i64 - verify emulation via igc-emu64ops
; RUN: ocloc compile -spirv_input -file %t.spv -device dg2 -options " -igc_opts 'PrintToConsole=1 PrintAfter=igc-emu64ops'" 2>&1 | FileCheck %s --check-prefix=CHECK-EMU64
; RUN: ocloc compile -spirv_input -file %t.spv -device dg2 -options " -igc_opts 'DumpVISAASMToConsole=1'" | FileCheck %s --check-prefix=CHECK-VISA
;
; PVC: native i64 - verify sub i64 survives and compilation succeeds
; RUN: ocloc compile -spirv_input -file %t.spv -device pvc -options " -igc_opts 'PrintToConsole=1 PrintBefore=EmitPass'" 2>&1 | FileCheck %s --check-prefix=CHECK-NATIVE64
; RUN: ocloc compile -spirv_input -file %t.spv -device pvc -options " -igc_opts 'DumpVISAASMToConsole=1'" | FileCheck %s --check-prefix=CHECK-VISA-PVC

               OpCapability Addresses
               OpCapability Int64
               OpCapability Kernel
               OpMemoryModel Physical64 OpenCL
               OpEntryPoint Kernel %main "test_ISubBorrow"
               OpName %a32 "a32"
               OpName %b32 "b32"
               OpName %a64 "a64"
               OpName %b64 "b64"
               OpName %out "out"
       %void = OpTypeVoid
       %uint = OpTypeInt 32 0
      %ulong = OpTypeInt 64 0
 %uint_struct = OpTypeStruct %uint %uint
%ulong_struct = OpTypeStruct %ulong %ulong
   %ptr_uint = OpTypePointer CrossWorkgroup %uint
          %9 = OpTypeFunction %void %uint %uint %ulong %ulong %ptr_uint
     %uint_0 = OpConstant %uint 0
     %uint_1 = OpConstant %uint 1
       %main = OpFunction %void None %9
        %a32 = OpFunctionParameter %uint
        %b32 = OpFunctionParameter %uint
        %a64 = OpFunctionParameter %ulong
        %b64 = OpFunctionParameter %ulong
        %out = OpFunctionParameter %ptr_uint
      %entry = OpLabel
     %res32  = OpISubBorrow %uint_struct %a32 %b32
    %diff32  = OpCompositeExtract %uint %res32 0
 %borrow32   = OpCompositeExtract %uint %res32 1
     %res64  = OpISubBorrow %ulong_struct %a64 %b64
    %diff64  = OpCompositeExtract %ulong %res64 0
 %borrow64   = OpCompositeExtract %ulong %res64 1
%diff64_32   = OpUConvert %uint %diff64
%borrow64_32 = OpUConvert %uint %borrow64
    %total   = OpIAdd %uint %diff32 %borrow32
   %total2   = OpIAdd %uint %total %diff64_32
   %total3   = OpIAdd %uint %total2 %borrow64_32
               OpStore %out %total3
               OpReturn
               OpFunctionEnd

; CHECK-TRANSLATE: call { i32, i1 } @llvm.usub.with.overflow.i32(i32 %a32, i32 %b32)
; CHECK-TRANSLATE: zext i1 {{%[0-9]+}} to i32
; CHECK-TRANSLATE: call { i64, i1 } @llvm.usub.with.overflow.i64(i64 %a64, i64 %b64)
; CHECK-TRANSLATE: zext i1 {{%[0-9]+}} to i64

; DG2: after igc-emu64ops, i64 sub+borrow decomposed to i32 pairs
; i32 path: sub + icmp ugt (borrow detection)
; CHECK-EMU64: define spir_kernel void @test_ISubBorrow
; CHECK-EMU64: %[[SUB32:[0-9]+]] = sub i32 %a32, %b32
; CHECK-EMU64-NEXT: %[[BRW32:[0-9]+]] = icmp ugt i32 %[[SUB32]], %a32
; CHECK-EMU64-NEXT: %{{[0-9]+}} = zext i1 %[[BRW32]] to i32
; i64 sub: emulated via GenISA.sub.pair
; CHECK-EMU64: call { i32, i32 } @llvm.genx.GenISA.sub.pair(i32 %{{[0-9]+}}, i32 %{{[0-9]+}}, i32 %{{[0-9]+}}, i32 %{{[0-9]+}})
; i64 borrow: decomposed to i32 pair compare (icmp ugt on result halves)
; CHECK-EMU64: icmp ugt i32
; CHECK-EMU64: icmp eq i32
; CHECK-EMU64-NOT: sub i64
; CHECK-EMU64-NOT: icmp{{.*}}i64
; CHECK-EMU64-NOT: call {{.*}} @llvm.usub.with.overflow

; PVC: native i64 sub preserved, borrow compare decomposed (no native i64 icmp)
; CHECK-NATIVE64: define spir_kernel void @test_ISubBorrow
; CHECK-NATIVE64: sub i64 %a64, %b64
; CHECK-NATIVE64-NOT: call {{.*}} @llvm.genx.GenISA.sub.pair
; CHECK-NATIVE64-NOT: call {{.*}} @llvm.usub.with.overflow

; CHECK-VISA: .kernel "test_ISubBorrow"

; CHECK-VISA-PVC: .kernel "test_ISubBorrow"
