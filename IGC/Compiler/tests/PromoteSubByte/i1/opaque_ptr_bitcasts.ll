; RUN: igc_opt --opaque-pointers -igc-promote-sub-byte -S %s | FileCheck %s
; Verifies that the opaque ptr bitcasts are promoted correctly.

target triple = "spir64-unknown-unknown"

%struct = type { i1 }

@foo = internal global %struct { i1 undef }

@foo.adr = internal addrspace(3) global %struct { i1 undef }

define i1 @bitcast() {
; CHECK-LABEL: @bitcast(
; CHECK-NEXT:    [[TMP1:%.*]] = load i8, ptr @foo, align 1
; CHECK-NEXT:    [[TMP2:%.*]] = trunc i8 [[TMP1]] to i1
; CHECK-NEXT:    [[TMP3:%.*]] = zext i1 [[TMP2]] to i8
; CHECK-NEXT:    ret i8 [[TMP3]]
;
  %bitcast = bitcast ptr @foo to ptr
  %val = load i1, ptr %bitcast, align 1
  ret i1 %val
}

define i1 @adr() {
; CHECK-LABEL: @adr(
; CHECK-NEXT:    [[TMP1:%.*]] = load i8, ptr addrspace(3) @foo.adr, align 1
; CHECK-NEXT:    [[TMP2:%.*]] = trunc i8 [[TMP1]] to i1
; CHECK-NEXT:    [[TMP3:%.*]] = zext i1 [[TMP2]] to i8
; CHECK-NEXT:    ret i8 [[TMP3]]
;
  %bitcast = bitcast ptr addrspace(3) @foo.adr to ptr addrspace(3)
  %val = load i1, ptr addrspace(3) %bitcast, align 1
  ret i1 %val
}

define i1 @no_bitcast() {
; CHECK-LABEL: @no_bitcast(
; CHECK-NEXT:    [[TMP1:%.*]] = load i8, ptr @foo, align 1
; CHECK-NEXT:    [[TMP2:%.*]] = trunc i8 [[TMP1]] to i1
; CHECK-NEXT:    [[TMP3:%.*]] = zext i1 [[TMP2]] to i8
; CHECK-NEXT:    ret i8 [[TMP3]]
;
  %val = load i1, ptr @foo, align 1
  ret i1 %val
}

