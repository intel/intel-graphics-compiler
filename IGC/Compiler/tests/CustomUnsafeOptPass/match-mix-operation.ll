; RUN: igc_opt -igc-custom-unsafe-opt-pass -S < %s | FileCheck %s

; CustomUnsafeOptPass::matchMixOperation - the linear-interpolation (mix/lerp)
; pattern  t*a + (1-t)*b  is recognized and reassociated into  (a-b)*t + b,
; which saves a multiply. The (1-t) comes from an fsub with a constant 1.0.

define float @test_match_mix(float %a, float %b, float %t) {
; CHECK-LABEL: define {{[^@]+}}@test_match_mix
; CHECK-SAME: (float [[A:%.*]], float [[B:%.*]], float [[T:%.*]]) {
; CHECK-NEXT:    [[TMP1:%.*]] = fmul fast float [[B]], [[T]]
; CHECK-NEXT:    [[TMP2:%.*]] = fsub fast float [[B]], [[TMP1]]
; CHECK-NEXT:    [[MUL2:%.*]] = fmul fast float [[T]], [[A]]
; CHECK-NEXT:    [[TMP3:%.*]] = fsub fast float [[A]], [[B]]
; CHECK-NEXT:    [[TMP4:%.*]] = fmul fast float [[T]], [[TMP3]]
; CHECK-NEXT:    [[TMP5:%.*]] = fadd fast float [[TMP4]], [[B]]
; CHECK-NEXT:    [[ADD:%.*]] = fadd fast float [[MUL2]], [[TMP2]]
; CHECK-NEXT:    ret float [[TMP5]]
;
  %sub = fsub fast float 1.000000e+00, %t
  %mul1 = fmul fast float %sub, %b
  %mul2 = fmul fast float %t, %a
  %add = fadd fast float %mul2, %mul1
  ret float %add
}
