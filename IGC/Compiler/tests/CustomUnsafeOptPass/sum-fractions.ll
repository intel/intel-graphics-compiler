; CustomUnsafeOptPass::visitBinaryOperatorDivAddDiv - the sum of two fractions
; a/b + c/d is combined into a single division (a*d + c*b) / (b*d). Gated by the
; EnableSumFractions regkey (off by default), so the pass's default LIT suite
; never exercises this path.

define float @test_sum_fractions(float %a, float %b, float %c, float %d) {
; CHECK-LABEL: define {{[^@]+}}@test_sum_fractions
; CHECK-SAME: (float [[A:%.*]], float [[B:%.*]], float [[C:%.*]], float [[D:%.*]]) {
; CHECK-NEXT:    [[TMP1:%.*]] = fdiv fast float 1.000000e+00, [[B]]
; CHECK-NEXT:    [[TMP2:%.*]] = fdiv fast float 1.000000e+00, [[D]]
; CHECK-NEXT:    [[TMP3:%.*]] = fmul fast float [[A]], [[D]]
; CHECK-NEXT:    [[TMP4:%.*]] = fmul fast float [[C]], [[B]]
; CHECK-NEXT:    [[TMP5:%.*]] = fmul fast float [[B]], [[D]]
; CHECK-NEXT:    [[TMP6:%.*]] = fdiv fast float 1.000000e+00, [[TMP5]]
; CHECK-NEXT:    [[TMP7:%.*]] = fadd fast float [[TMP3]], [[TMP4]]
; CHECK-NEXT:    [[TMP8:%.*]] = fmul fast float [[TMP7]], [[TMP6]]
; CHECK-NEXT:    ret float [[TMP8]]
;
  %ab = fdiv fast float %a, %b
  %cd = fdiv fast float %c, %d
  %s = fadd fast float %ab, %cd
