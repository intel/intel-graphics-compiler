; REQUIRES: regkeys
; RUN: igc_opt --regkey EnablePowToLogMulExp=1 -igc-custom-unsafe-opt-pass -S < %s | FileCheck %s

; CustomUnsafeOptPass strength reduction of pow with a non-special (variable)
; exponent:  pow(x, y) => exp2(log2(x) * y).  Gated by the EnablePowToLogMulExp
; regkey (off by default), so the pass's default LIT suite never exercises this
; branch (the constant 2/4/8/0.5 exponents take other, unconditional paths).

define float @test_pow_to_log_mul_exp(float %x, float %y) {
; CHECK-LABEL: define {{[^@]+}}@test_pow_to_log_mul_exp
; CHECK-SAME: (float [[X:%.*]], float [[Y:%.*]]) {
; CHECK-NEXT:    [[TMP1:%.*]] = call fast float @llvm.log2.f32(float [[X]])
; CHECK-NEXT:    [[TMP2:%.*]] = fmul fast float [[TMP1]], [[Y]]
; CHECK-NEXT:    [[TMP3:%.*]] = call fast float @llvm.exp2.f32(float [[TMP2]])
; CHECK-NEXT:    ret float [[TMP3]]
;
  %p = call fast float @llvm.pow.f32(float %x, float %y)
  ret float %p
}

declare float @llvm.pow.f32(float, float)
