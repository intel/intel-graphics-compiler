; Check no assert is triggered on long symbol name (>1024).

; RUN: igc_opt --opaque-pointers %s -S -igc-emit-visa

target datalayout = "e-p:64:64:64-i1:8:8-i8:8:8-i16:16:16-i32:32:32-i64:64:64-f32:32:32-f64:64:64-v16:16:16-v24:32:32-v32:32:32-v48:64:64-v64:64:64-v96:128:128-v128:128:128-v192:256:256-v256:256:256-v512:512:512-v1024:1024:1024-n8:16:32"
target triple = "spir64-unknown-unknown"

@ = addrspace(1) constant [4 x i32] [i32 0, i32 0, i32 64, i32 64]
@llvm.used = appending global [1 x ptr] [ptr addrspacecast (ptr addrspace(1) @ to ptr)], section "llvm.metadata"

; Function Attrs: convergent null_pointer_is_valid
declare spir_kernel void @test(<8 x i32>, <3 x i32>, ptr addrspace(1), ptr addrspace(1), ptr addrspace(1), i32) #0

; Function Attrs: null_pointer_is_valid
define spir_kernel void @Intel_Symbol_Table_Void_Program() #1 {
entry:
  ret void, !stats.blockFrequency.digits !25, !stats.blockFrequency.scale !26
}

attributes #0 = { convergent null_pointer_is_valid }
attributes #1 = { null_pointer_is_valid }

!igc.functions = !{!0, !11}
!IGCMetadata = !{!13}
!opencl.ocl.version = !{!22, !22}
!opencl.spir.version = !{!22, !22}
!llvm.ident = !{!23, !23}
!llvm.module.flags = !{!24}

!0 = !{ptr @test, !1}
!1 = !{!2, !3}
!2 = !{!"function_type", i32 0}
!3 = !{!"implicit_arg_desc", !4, !5, !6, !7, !8, !9}
!4 = !{i32 0}
!5 = !{i32 2}
!6 = !{i32 12}
!7 = !{i32 57}
!8 = !{i32 58}
!9 = !{i32 54, !10}
!10 = !{!"explicit_arg_num", i32 2}
!11 = !{ptr @Intel_Symbol_Table_Void_Program, !12}
!12 = !{!2}
!13 = !{!"ModuleMD", !14, !19}
!14 = !{!"FuncMD", !15, !16, !17, !18}
!15 = !{!"FuncMDMap[0]", ptr @test}
!16 = !{!"FuncMDValue[0]"}
!17 = !{!"FuncMDMap[1]", ptr @Intel_Symbol_Table_Void_Program}
!18 = !{!"FuncMDValue[1]"}
!19 = !{!"inlineProgramScopeOffsets", !20, !21}
!20 = !{!"inlineProgramScopeOffsetsMap[0]", ptr addrspace(1) @}
!21 = !{!"inlineProgramScopeOffsetsValue[0]", i64 0}
!22 = !{i32 2, i32 0}
!23 = !{!"clang version 14.0.5"}
!24 = !{i32 1, !"wchar_size", i32 4}
!25 = !{!"80"}
!26 = !{!"-3"}
