@LIT_SITE_CFG_IN_HEADER@

import sys
import lit.llvm

config.asan_runtime_lib = "@IGC_BUILD__ASAN_RUNTIME_LIB@"
config.llvm_tools_dir = "@LLVM_TOOLS_DIR@"
config.test_run_dir = "@CMAKE_CURRENT_BINARY_DIR@"
config.igc_lib_dir = "@IGC_LIBRARY_DIR@"
config.igc_lib_path = "@IGC_LIBRARY_FILE@"
config.interface_tester_dir = "$<$<TARGET_EXISTS:IGCOCLInterfaceTester>:$<TARGET_FILE_DIR:IGCOCLInterfaceTester>>"

# Mimic the c++ (define) IGC_DEBUG_VARIABLES
# regkeys are supported on Linux Release too
config.regkeys_disabled = $<AND:$<CONFIG:Release>,$<BOOL:"@MSVC@">>

lit.llvm.initialize(lit_config, config)
lit_config.load_config(config, "@INTERFACE_TEST_SOURCE_DIR@/lit.cfg.py")
