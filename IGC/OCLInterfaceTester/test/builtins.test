# The inputs are provided on stdin: items=2048,
# rangeSize=64, 4-byte value, so we check the computed result.

# RUN: IGCOCLInterfaceTester builtins < %s 2>&1 | FileCheck %s

items=2048
rangeSize=64
valueTypeSizeInBytes=4

# CHECK: supported=1
# CHECK-NEXT: globalMemoryInBytes=73736
# CHECK-NEXT: sharedMemoryInBytes=0
# CHECK-NEXT: canMemoryBeUsedConcurrently=0
