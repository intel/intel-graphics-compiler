# The gtsysinfo is a sub-interface of Interface No. 1.

# RUN: IGCOCLInterfaceTester gtsysinfo < %s 2>&1 | FileCheck %s

EUCount=512
L3CacheSizeInKb=4096
IsL3HashModeEnabled=1
MaxDualSubSlicesSupported=32
SLMSizeInKb=64

