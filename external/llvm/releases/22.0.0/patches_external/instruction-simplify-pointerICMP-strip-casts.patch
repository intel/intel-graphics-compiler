This PR adds stripPointerCasts in simplifyICmpWithZero.
This patch is closely related to instruction-simplify-pointerICMP-strip-casts.patch for LLVM 17.

The only difference is that stripPointerCasts is added in simplifyICmpWithZero instead of computePointerICmp, because
simplification of Pointer ICmp with zero was moved from computepointerICmp to simplifyICmpWithZero in this commit:
https://github.com/llvm/llvm-project/commit/4638c29c3dd14048ca78e37f132d4c75f490d139

I've found that in some case(s) it caused e.g function inliner to fail where on LLVM 16 or 17 with mentioned earlier patch it worked better.

Repro, where on LLVM 16/17 with patch "%1 = icmp eq i64 %0, 0" is fully removed

    ; Function Attrs: nounwind
    define spir_kernel void @main1(i1 %branch1, i1 %branch2) {
    entry:
        %kernel = alloca i32, align 8

        %bitcast1 = bitcast ptr %kernel to ptr
        %data = getelementptr inbounds i8, ptr %bitcast1, i64 8
        %data2 = addrspacecast ptr %data to ptr addrspace(4)
        br i1 %branch1, label %callBranch, label %exit

    callBranch:
        call spir_func void @main2(ptr addrspace(4) align 8 dereferenceable(40) %data2, i1 %branch2)
        br label %exit

    exit:
        ret void
    }

    ; Function Attrs: alwaysinline nounwind
    define internal spir_func void @main2(ptr addrspace(4) align 8 dereferenceable(40) %data, i1 %branch2)
    {
    entry:
        %args17 = alloca i32, align 8
        br i1 %branch2, label %if.else, label %exit

    if.else:
        %args17.ascast = addrspacecast ptr %args17 to ptr addrspace(4)
        call spir_func void @main3(ptr addrspace(4) %args17.ascast)
        br label %exit

    exit:
        ret void
    }

    ; Function Attrs: alwaysinline nounwind
    define internal spir_func void @main3(ptr addrspace(4) %args) {
    entry:
    %default_args = alloca i32, align 8
    %0 = ptrtoint ptr addrspace(4) %args to i64
    %1 = icmp eq i64 %0, 0
    br i1 %1, label %branch1, label %branch2

    branch1:
    %default_args.ascast = addrspacecast ptr %default_args to ptr addrspace(4)
    br label %combined

    branch2:
    %src = bitcast ptr addrspace(4) %args to ptr addrspace(4)
    br label %combined

    combined:
    %args.addr.017 = phi ptr addrspace(4) [ %default_args.ascast, %branch1 ], [ %src, %branch2 ]
    store ptr addrspace(4) %args, ptr addrspace(4) %args.addr.017, align 4
    br label %exit

    exit:
    ret void
    }


