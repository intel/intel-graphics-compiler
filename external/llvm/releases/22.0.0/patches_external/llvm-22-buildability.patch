From: Aleksander Mielczarek <aleksander.mielczarek@intel.com>
Date: Mon, 18 May 2026 00:00:00 +0000
Subject: [PATCH] [IGC LLVM22] Temporary workaround for LLVM 22 buildability

TEMPORARY WORKAROUND: This patch restores deprecated APIs removed in LLVM 22
that are still used by IGC. It is intended as a short-term fix to unblock
compilation while the IGC codebase is migrated to the new LLVM 22 APIs.
This patch should be removed once IGC has been fully ported.

---

diff --git a/llvm/include/llvm/ADT/PointerUnion.h b/llvm/include/llvm/ADT/PointerUnion.h
index d9087dd1c516..2f38555d9793 100644
--- a/llvm/include/llvm/ADT/PointerUnion.h
+++ b/llvm/include/llvm/ADT/PointerUnion.h
@@ -151,7 +151,6 @@ public:
   ///
   /// If the specified pointer type is incorrect, assert.
   template <typename T>
-  [[deprecated("Use cast instead")]]
   inline T get() const {
     assert(isa<T>(*this) && "Invalid accessor called");
     return cast<T>(*this);
diff --git a/llvm/include/llvm/ADT/StringRef.h b/llvm/include/llvm/ADT/StringRef.h
index 09c6d6d6eab0..ea8ed00727be 100644
--- a/llvm/include/llvm/ADT/StringRef.h
+++ b/llvm/include/llvm/ADT/StringRef.h
@@ -168,6 +168,14 @@ namespace llvm {
       return StringRef(S, size());
     }
 
+    [[nodiscard]] bool equals(StringRef RHS) const {
+      if (size() != RHS.size())
+        return false;
+      if (empty())
+        return true;
+      return ::memcmp(data(), RHS.data(), size()) == 0;
+    }
+
     /// Check for string equality, ignoring case.
     [[nodiscard]] bool equals_insensitive(StringRef RHS) const {
       return size() == RHS.size() && compare_insensitive(RHS) == 0;
@@ -265,6 +273,13 @@ namespace llvm {
     [[nodiscard]] bool starts_with(char Prefix) const {
       return !empty() && front() == Prefix;
     }
+    [[nodiscard]] bool startswith(StringRef Prefix) const {
+      return size() >= Prefix.size() &&
+             compareMemory(data(), Prefix.data(), Prefix.size()) == 0;
+    }
+    [[nodiscard]] bool startswith(char Prefix) const {
+      return !empty() && front() == Prefix;
+    }
 
     /// Check if this string starts with the given \p Prefix, ignoring case.
     [[nodiscard]] LLVM_ABI bool starts_with_insensitive(StringRef Prefix) const;
@@ -278,6 +293,15 @@ namespace llvm {
     [[nodiscard]] bool ends_with(char Suffix) const {
       return !empty() && back() == Suffix;
     }
+    /// Check if this string ends with the given \p Suffix.
+    [[nodiscard]] bool endswith(StringRef Suffix) const {
+      return size() >= Suffix.size() &&
+             compareMemory(end() - Suffix.size(), Suffix.data(),
+                           Suffix.size()) == 0;
+    }
+    [[nodiscard]] bool endswith(char Suffix) const {
+      return !empty() && back() == Suffix;
+    }
 
     /// Check if this string ends with the given \p Suffix, ignoring case.
     [[nodiscard]] LLVM_ABI bool ends_with_insensitive(StringRef Suffix) const;
diff --git a/llvm/include/llvm/Analysis/TargetLibraryInfo.h b/llvm/include/llvm/Analysis/TargetLibraryInfo.h
index 0f98af69f12c..28d6f730cc8c 100644
--- a/llvm/include/llvm/Analysis/TargetLibraryInfo.h
+++ b/llvm/include/llvm/Analysis/TargetLibraryInfo.h
@@ -19,6 +19,7 @@
 #include "llvm/Pass.h"
 #include "llvm/Support/Compiler.h"
 #include "llvm/TargetParser/Triple.h"
+#include "llvm/Analysis/CallGraphSCCPass.h"
 #include <bitset>
 #include <optional>
 
diff --git a/llvm/include/llvm/IR/Instruction.h b/llvm/include/llvm/IR/Instruction.h
index 11385666e7ff..499a59381d2b 100644
--- a/llvm/include/llvm/IR/Instruction.h
+++ b/llvm/include/llvm/IR/Instruction.h
@@ -53,9 +53,7 @@ class InsertPosition {
 
 public:
   InsertPosition(std::nullptr_t) : InsertAt() {}
-  LLVM_ABI LLVM_DEPRECATED("Use BasicBlock::iterators for insertion instead",
-                           "BasicBlock::iterator")
-      InsertPosition(Instruction *InsertBefore);
+  InsertPosition(Instruction *InsertBefore);
   LLVM_ABI InsertPosition(BasicBlock *InsertAtEnd);
   InsertPosition(InstListType::iterator InsertAt) : InsertAt(InsertAt) {}
   operator InstListType::iterator() const { return InsertAt; }
@@ -213,8 +211,7 @@ public:
   /// start of a block such as BasicBlock::getFirstNonPHIIt must be passed into
   /// insertBefore without unwrapping/rewrapping. For all other positions, call
   /// getIterator to fetch the instruction iterator.
-  LLVM_ABI LLVM_DEPRECATED("Use iterators as instruction positions",
-                           "") void insertBefore(Instruction *InsertPos);
+  void insertBefore(Instruction *InsertPos);
 
   /// Insert an unlinked instruction into a basic block immediately before
   /// the specified position.
@@ -242,8 +239,7 @@ public:
   /// start of a block such as BasicBlock::getFirstNonPHIIt must be passed into
   /// moveBefore without unwrapping/rewrapping. For all other positions, call
   /// getIterator to fetch the instruction iterator.
-  LLVM_ABI LLVM_DEPRECATED("Use iterators as instruction positions",
-                           "") void moveBefore(Instruction *MovePos);
+  void moveBefore(Instruction *MovePos);
 
   /// Unlink this instruction from its current basic block and insert it into
   /// the basic block that MovePos lives in, right before MovePos.
@@ -265,8 +261,7 @@ public:
   ///
   /// Deprecated in favour of the iterator-accepting flavour of
   /// moveBeforePreserving, as all insertions should be at iterator positions.
-  LLVM_ABI LLVM_DEPRECATED("Use iterators as instruction positions",
-                           "") void moveBeforePreserving(Instruction *MovePos);
+  void moveBeforePreserving(Instruction *MovePos);
 
 private:
   /// RemoveDIs project: all other moves implemented with this method,
diff --git a/llvm/include/llvm/IR/Type.h b/llvm/include/llvm/IR/Type.h
index 1c042500ba8e..ac85146aa4a5 100644
--- a/llvm/include/llvm/IR/Type.h
+++ b/llvm/include/llvm/IR/Type.h
@@ -484,8 +484,7 @@ public:
   /// Return a pointer to the current type. This is equivalent to
   /// PointerType::get(Ctx, AddrSpace).
   /// TODO: Remove this after opaque pointer transition is complete.
-  LLVM_ABI LLVM_DEPRECATED("Use PointerType::get instead", "PointerType::get")
-      PointerType *getPointerTo(unsigned AddrSpace = 0) const;
+  PointerType *getPointerTo(unsigned AddrSpace = 0) const;
 
 private:
   /// Derived types like structures and arrays are sized iff all of the members
--
2.43.0
