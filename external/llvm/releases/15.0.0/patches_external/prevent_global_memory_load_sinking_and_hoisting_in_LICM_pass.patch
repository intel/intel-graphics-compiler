If the loaded memory is global it can be changed outside the thread.
We avoid the global load instructions hoisting or sinking, although such 
optimization is legal under certain conditions.
This workaround fix is intended to improve the user experience.
Lit test to test the feature: LICM/global_loads.ll

---
diff --git a/llvm/lib/Transforms/Scalar/LICM.cpp b/llvm/lib/Transforms/Scalar/LICM.cpp
index f54264b1d..6f7e7da13 100644
--- a/llvm/lib/Transforms/Scalar/LICM.cpp
+++ b/llvm/lib/Transforms/Scalar/LICM.cpp
@@ -1159,6 +1159,11 @@ bool llvm::canSinkOrHoistInst(Instruction &I, AAResults *AA, DominatorTree *DT,
     if (LI->isAtomic() && !TargetExecutesOncePerLoop)
       return false; // Don't risk duplicating unordered loads
 
+    // If the loaded memory is global it can be changed outside the thread,
+    // in this case we avoid the instruction hoisting or sinking.
+    if (LI->getOperand(0)->getType()->getPointerAddressSpace() == 1)
+      return false;
+
     // This checks for an invariant.start dominating the load.
     if (isLoadInvariantInLoop(LI, DT, CurLoop))
       return true;
@@ -1234,6 +1239,13 @@ bool llvm::canSinkOrHoistInst(Instruction &I, AAResults *AA, DominatorTree *DT,
         return true;
       }

+      // If the loaded memory is global it can be changed outside the thread,
+      // in this case we avoid the instruction hoisting or sinking.
+      for (Value *Op : CI->args())
+        if (Op->getType()->isPointerTy() &&
+          Op->getType()->getPointerAddressSpace() == 1)
+          return false;
+
       // If this call only reads from memory and there are no writes to memory
       // in the loop, we can hoist or sink the call as appropriate.
       if (isReadOnly(MSSAU, CurLoop))
