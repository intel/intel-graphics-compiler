This optimization was found to cause performance regression. As of now I'm disabling it

https://github.com/llvm/llvm-project/commit/91cdffcb2f9ea0b8beac8600d0544c0ae3836682

diff --git a/llvm/lib/Transforms/InstCombine/InstCombineAddSub.cpp b/llvm/lib/Transforms/InstCombine/InstCombineAddSub.cpp
index 91ca44e0f11e..3b0358cc461b 100644
--- a/llvm/lib/Transforms/InstCombine/InstCombineAddSub.cpp
+++ b/llvm/lib/Transforms/InstCombine/InstCombineAddSub.cpp
@@ -1383,8 +1383,12 @@ Instruction *InstCombinerImpl::visitAdd(BinaryOperator &I) {
   if (Instruction *X = foldNoWrapAdd(I, Builder))
     return X;

-  if (Instruction *R = foldBinOpShiftWithShift(I))
-    return R;
+  // Disabling this optimization due to performance regression in some workloads,
+  // more details in PR introducing this .patch:
+  // file: InstCombine-disable-fold-bin-op-shift-with-shift.patch
+
+  // if (Instruction *R = foldBinOpShiftWithShift(I))
+  //   return R;

   Value *LHS = I.getOperand(0), *RHS = I.getOperand(1);
   Type *Ty = I.getType();