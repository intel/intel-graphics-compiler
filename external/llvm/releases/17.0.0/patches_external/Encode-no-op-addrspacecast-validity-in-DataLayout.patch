+bool DataLayout::isNoopAddrSpaceCast(unsigned SrcAS, unsigned DstAS) const {
+  if (SrcAS == DstAS)
+    return true;
+  for (const auto &Group : NoopAddrSpaceCastGroups)
+    if (is_contained(Group, SrcAS) && is_contained(Group, DstAS))
+      return true;
+  return false;
+}
